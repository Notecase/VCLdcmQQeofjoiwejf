# =============================================================================
# @inkdown/api - Environment Variables
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=development

# =============================================================================
# Supabase (Required)
# =============================================================================

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Service role key (for backend operations, bypasses RLS)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY=eyJ...

# Anon key (for user-authenticated requests)
# Get from: Supabase Dashboard > Settings > API > anon key
SUPABASE_ANON_KEY=eyJ...

# =============================================================================
# AI Providers
# =============================================================================

# OpenAI (Required for embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (Recommended for chat)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Optional, for Gemini)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=...

# =============================================================================
# Model Configuration
# =============================================================================

# Default model for chat completions
DEFAULT_CHAT_MODEL=claude-sonnet-4-20250514

# Default model for embeddings
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large

# Embedding dimensions (must match database schema: 1536)
EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Rate Limiting
# =============================================================================

# Requests per minute per user
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Total tokens per day per user
RATE_LIMIT_TOKENS_PER_DAY=100000

# =============================================================================
# CORS
# =============================================================================

# Allowed origin for CORS (your frontend URL)
CORS_ORIGIN=http://localhost:5173
