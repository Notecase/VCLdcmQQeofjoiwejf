{
  "name": "@noteshell/mcp",
  "version": "0.4.0",
  "description": "Noteshell MCP Server — 43 pure-data tools for notes, planning, and learning. Zero AI calls.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "scripts",
    "SKILL.md",
    "skills"
  ],
  "bin": {
    "noteshell": "scripts/noteshell.mjs",
    "noteshell-mcp": "dist/index.js",
    "noteshell-setup": "scripts/setup.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "node --test test/device-auth.test.mjs"
  },
  "dependencies": {
    "@inkdown/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@supabase/supabase-js": "^2.49.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.7.0"
  }
}
