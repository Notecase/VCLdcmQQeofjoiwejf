# Supabase
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI Provider
ANTHROPIC_API_KEY=your-anthropic-api-key

# Provider Selection (supabase | local)
VITE_PROVIDER=supabase

# API Server (apps/api)
API_PORT=3001
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_CLOUD_URL=https://ollama.com
RESEARCH_MODEL=gpt-4o-mini
RESEARCH_NOTE_DRAFT_MODEL=gpt-5.2
RESEARCH_ARTIFACT_MODEL=kimi-k2.5
RESEARCH_ARTIFACT_FALLBACK_MODEL=gpt-5.2
EDITOR_DEEP_AGENT_ENABLED=true
EDITOR_DEEP_AGENT_USER_ALLOWLIST=
EDITOR_DEEP_AGENT_KILL_SWITCH=false
EDITOR_DEEP_AGENT_HISTORY_WINDOW_TURNS=12

# Web App (optional)
VITE_API_BASE=/api/agent

# Demo mode
VITE_DEMO_PASSWORD=noteshell2026
